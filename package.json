{
  "name": "@uluops/setup",
  "version": "0.9.4",
  "description": "Zero-friction installer for UluOps agentic harnesses",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Uluops/-uluops-setup.git"
  },
  "homepage": "https://uluops.ai",
  "keywords": [
    "uluops",
    "mcp",
    "agents",
    "claude",
    "opencode",
    "agentic",
    "harness",
    "setup",
    "installer"
  ],
  "type": "module",
  "bin": {
    "uluops-setup": "./dist/cli.js"
  },
  "exports": {
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/cli.d.ts",
    "dist/cli/**",
    "dist/lib/**",
    "dist/steps/**",
    "dist/harnesses/**",
    "dist/commands/**",
    "assets"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "7.10.1",
    "@uluops/agent-metrics": "0.4.0",
    "chalk": "5.6.2",
    "commander": "12.1.0",
    "jsonc-parser": "3.3.1"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
