{
  "name": "@uluops/setup",
  "version": "0.3.0",
  "description": "Zero-friction installer for UluOps agentic harnesses",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Uluops/-uluops-setup.git"
  },
  "homepage": "https://uluops.ai",
  "keywords": [
    "uluops",
    "mcp",
    "agents",
    "claude",
    "opencode",
    "agentic",
    "harness",
    "setup",
    "installer"
  ],
  "type": "module",
  "bin": {
    "uluops-setup": "./dist/cli.js"
  },
  "exports": {
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/cli.d.ts",
    "dist/lib/**",
    "dist/steps/**",
    "dist/harnesses/**",
    "assets"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@uluops/agent-metrics": "^0.2.0",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
